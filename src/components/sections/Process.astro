---
const steps = [
  {
    num: '01',
    tag: 'Strategiecall',
    title: 'Klarheit',
    titleEm: 'schaffen.',
    desc: '30 Minuten mit Max — wir analysieren dein Portfolio und identifizieren die größten Hebel. Kostenlos und unverbindlich.',
    bullets: ['Portfolio-Kurzcheck in Echtzeit', 'Potenziale & Engpässe identifizieren', 'Konkreter Fahrplan — kein Verkaufsgespräch'],
  },
  {
    num: '02',
    tag: 'KI-Analyse',
    title: 'Durchrechnen',
    titleEm: 'lassen.',
    desc: 'Innerhalb von 48h erhältst du deinen persönlichen KI-Report. Cashflow, Steuern, Finanzierung, Wertsteigerung — auf den Euro genau.',
    bullets: ['Analyse aller Einheiten & Standorte', 'Steueroptimierung & Fördermittel-Check', 'Exit-Szenarien & Finanzierungsstruktur'],
  },
  {
    num: '03',
    tag: 'Umsetzung',
    title: 'Profitieren',
    titleEm: '— sofort.',
    desc: 'Schritt-für-Schritt Fahrplan mit Vorlagen, Videoanleitungen und persönlichem Support. Du setzt um — mit System.',
    bullets: ['Videoakademie + Umsetzungs-Vorlagen', 'Professionelle Gutachten & Fahrpläne', '12 Monate Support & Geld-zurück-Garantie'],
  },
]
---

<section class="proc-section" id="process">
  <div class="proc-container">
    <div class="proc-header reveal">
      <span class="proc-label">So funktioniert's</span>
      <h2 class="proc-h2">
        Ein klarer Prozess für<br/>
        <em class="proc-em italic-gradient">maximale Ergebnisse.</em>
      </h2>
    </div>

    <div class="proc-stack">
      {steps.map((s, i) => (
        <>
          <div class="proc-card" style={`z-index:${i + 1}`}>
            <span class="proc-watermark">{s.num}</span>
            <div class="proc-left">
              <span class="proc-badge">{s.num}</span>
              <p class="proc-tag">{s.tag}</p>
              <h3 class="proc-title">{s.title}&nbsp;<em class="proc-title-em">{s.titleEm}</em></h3>
              <p class="proc-desc">{s.desc}</p>
              <ul class="proc-bullets">
                {s.bullets.map(b => (
                  <li class="proc-bullet"><span class="proc-dot"></span>{b}</li>
                ))}
              </ul>
            </div>
            <div class="proc-right">
              <span class="proc-num-big">{s.num}</span>
            </div>
          </div>
          {i < steps.length - 1 && <div class="proc-spacer"></div>}
        </>
      ))}
      <div class="proc-spacer"></div>
    </div>

    <div style="text-align:center; padding:64px 0 0;" class="reveal">
      <a href="#calendly" class="cta-btn">
        Jetzt Termin buchen
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12,5 19,12 12,19"/></svg>
      </a>
    </div>
  </div>
</section>

<style>
  .proc-section {
    padding: 140px 0 80px;
    background: var(--light);
    color: var(--text);
  }
  .proc-container {
    max-width: 1200px; margin: 0 auto; padding: 0 24px;
  }
  @media (min-width: 768px) { .proc-container { padding: 0 48px; } }

  .proc-header { margin-bottom: 80px; }
  .proc-label {
    font-family: 'Inter', sans-serif; font-size: 11px; font-weight: 700;
    letter-spacing: 0.14em; text-transform: uppercase; color: var(--blue);
  }
  .proc-h2 {
    font-size: clamp(32px, 5vw, 56px); line-height: 1.06;
    color: var(--text); margin: 16px 0 0;
  }
  .proc-em { font-style: italic; }

  .proc-stack { position: relative; }
  .proc-spacer { height: 55vh; pointer-events: none; }
  @media (max-width: 767px) { .proc-spacer { height: 30vh; } }

  /* ── Card ──────────────────────────────── */
  .proc-card {
    position: sticky;
    top: 88px;
    background: linear-gradient(180deg, #151515 0%, #0e0e0e 100%);
    border: none;
    border-radius: 24px;
    overflow: hidden;
    display: grid;
    grid-template-columns: 1fr;
    box-shadow:
      0 4px 16px rgba(0,0,0,0.35),
      0 16px 48px rgba(0,0,0,0.2);
    transition: box-shadow 0.4s;
  }
  .proc-card:hover {
    box-shadow:
      0 8px 24px rgba(0,0,0,0.4),
      0 24px 64px rgba(0,0,0,0.25),
      0 0 40px rgba(0,102,255,0.06);
  }

  /* Metallic glowing border — conic sweep */
  @property --card-angle { syntax: '<angle>'; initial-value: 0deg; inherits: false; }
  .proc-card::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    padding: 1px;
    background: linear-gradient(
      180deg,
      rgba(255,255,255,0.25) 0%,
      rgba(200,210,230,0.1) 30%,
      rgba(255,255,255,0.06) 50%,
      rgba(200,210,230,0.1) 70%,
      rgba(255,255,255,0.2) 100%
    );
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    mask-composite: exclude;
    z-index: 2;
    pointer-events: none;
  }
  @keyframes card-border-spin { to { --card-angle: 360deg; } }

  /* Inner content needs to be above the pseudo layers */
  .proc-left, .proc-right { position: relative; z-index: 1; }
  @media (min-width: 768px) {
    .proc-card {
      grid-template-columns: 55% 45%;
      min-height: 460px;
    }
  }

  .proc-watermark {
    position: absolute; top: -0.1em; right: 0;
    font-family: 'Inter', sans-serif; font-weight: 900;
    font-size: clamp(100px, 16vw, 200px); line-height: 0.85;
    letter-spacing: -0.06em; color: rgba(255,255,255,0.025);
    pointer-events: none; user-select: none; z-index: 0;
  }

  /* ── Left ──────────────────────────────── */
  .proc-left {
    position: relative; z-index: 1;
    padding: 36px 28px;
    display: flex; flex-direction: column; justify-content: center;
    color: #fff;
  }
  @media (min-width: 768px) { .proc-left { padding: 48px 44px; } }

  .proc-badge {
    display: inline-block; font-family: 'Inter', sans-serif;
    font-size: 12px; font-weight: 600; color: rgba(255,255,255,0.6);
    background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1);
    border-radius: 100px; padding: 4px 14px;
    margin-bottom: 20px; width: fit-content; letter-spacing: 0.04em;
  }
  .proc-tag {
    font-family: 'Inter', sans-serif; font-size: 11px; font-weight: 700;
    letter-spacing: 0.12em; text-transform: uppercase;
    color: var(--blue); margin: 0 0 16px;
  }
  .proc-title {
    font-family: 'Inter', sans-serif; font-weight: 800;
    font-size: clamp(26px, 3vw, 40px); letter-spacing: -0.03em;
    line-height: 1.08; color: #fff; margin: 0 0 16px;
  }
  .proc-title-em {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic; font-weight: 300;
    color: rgba(255,255,255,0.3);
  }
  .proc-desc {
    font-size: 14px; line-height: 1.7;
    color: rgba(255,255,255,0.5); margin: 0 0 24px; max-width: 420px;
  }
  .proc-bullets {
    list-style: none; padding: 0; margin: 0;
    display: flex; flex-direction: column; gap: 10px;
  }
  .proc-bullet {
    display: flex; align-items: center; gap: 12px;
    font-size: 14px; color: rgba(255,255,255,0.7);
  }
  .proc-dot {
    width: 6px; height: 6px; border-radius: 50%; flex-shrink: 0;
    background: var(--blue);
    box-shadow: 0 0 6px rgba(0,102,255,0.7), 0 0 16px rgba(0,102,255,0.3);
  }

  /* ── Right ─────────────────────────────── */
  .proc-right {
    position: relative; overflow: hidden;
    background: #0a0a0a;
    min-height: 200px;
    border-top: 1px solid rgba(255,255,255,0.05);
    display: flex; align-items: center; justify-content: center;
  }
  @media (min-width: 768px) {
    .proc-right {
      border-top: none;
      border-left: 1px solid rgba(255,255,255,0.05);
      min-height: auto;
    }
  }
  .proc-num-big {
    font-family: 'JetBrains Mono', monospace; font-weight: 700;
    font-size: clamp(80px, 12vw, 160px);
    background: linear-gradient(180deg, rgba(255,255,255,0.06) 0%, rgba(255,255,255,0.02) 100%);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
    letter-spacing: -0.04em;
  }
</style>
