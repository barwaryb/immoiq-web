---
const logos = [
  'Amazon Prime Video', 'WBD Gruppe', 'The Mittelstand',
  'Amazon Prime Video', 'WBD Gruppe', 'The Mittelstand',
  'Amazon Prime Video', 'WBD Gruppe',
]
---

<section class="logos-section s-light">
  <p class="logos-label">Bekannt aus</p>
  <div class="logos-track">
    <div class="logos-inner animate-marquee">
      {logos.map(name => (
        <span class="logo-item">{name}</span>
      ))}
    </div>
  </div>
</section>

<style>
  .logos-section {
    padding: 48px 0;
    border-top: 1px solid rgba(0,0,0,0.06);
    border-bottom: 1px solid rgba(0,0,0,0.06);
    overflow: hidden;
  }
  .logos-label {
    text-align: center;
    font-size: 11px; font-weight: 700;
    letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--text-muted);
    margin: 0 0 24px;
  }
  .logos-track { overflow: hidden; }
  .logos-inner { display: flex; width: max-content; }
  .logo-item {
    padding: 0 40px;
    font-family: 'Inter', sans-serif;
    font-weight: 600; font-size: 14px;
    color: rgba(0,0,0,0.25);
    white-space: nowrap;
    letter-spacing: -0.01em;
  }
</style>
