---
import VideoPlayer from '../ui/VideoPlayer.tsx'
---

<section class="hero-section s-white">
  <div class="container hero-container">

    <!-- Positioning statement — who we are, not what we sell -->
    <p class="hero-tag reveal">Portfoliooptimierung für Immobilienbesitzer</p>

    <!-- Transformation headline — Satoshi Bold + Cormorant Italic Gradient -->
    <h1 class="hero-h1 reveal reveal-d1">
      Wir optimieren dein<br/>
      Immobilienportfolio.<br/>
      <em class="italic-gradient">Auf den Euro genau.</em>
    </h1>

    <!-- Subline — answers "how?" briefly, builds curiosity for VSL -->
    <p class="hero-sub reveal reveal-d2">
      Die meisten Portfolios verschenken 40.000–50.000€ pro Jahr — durch fehlende
      Mietanpassungen, ungenutzte Steuervorteile und übersehene Fördermittel.
      Wir finden das Geld und zeigen dir, wie du es holst.
    </p>

    <!-- Dual CTA — primary + soft -->
    <div class="hero-cta reveal reveal-d3">
      <a href="#calendly" class="cta-btn">
        Kostenloses Erstgespräch
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12,5 19,12 12,19"/></svg>
      </a>
      <a href="#process" class="cta-btn-outline">So funktioniert's</a>
    </div>

    <!-- Trust — single line, understated -->
    <p class="hero-trust-line reveal reveal-d4">
      400M€ Transaktionsvolumen · 800+ Deals · 150+ eigene Einheiten
    </p>

  </div>
</section>

<!-- Full-bleed architectural image -->
<div class="image-breaker">
  <img src="/images/breaker-1.jpg" alt="Premium Immobilien" loading="eager" />
</div>

<!-- VSL Video — Max sells personally -->
<section class="s-white" style="padding: 100px 0 60px;">
  <div class="container" style="max-width: 900px;">
    <p class="vsl-intro reveal" style="text-align:center; margin-bottom:40px;">
      <span class="vsl-tag">2 Min. Video</span>
      <span class="vsl-title">Max Bertlein erklärt, warum bei jedem Portfolio Geld liegen bleibt.</span>
    </p>
    <div class="hero-video card reveal">
      <VideoPlayer
        client:load
        previewSrc="/video/preview.mp4"
        fullSrc="/video/vsl.mp4"
        posterSrc="/video/poster.jpg"
      />
    </div>
  </div>
</section>

<style>
  .hero-section { padding: 180px 0 80px; }
  @media (min-width: 768px) { .hero-section { padding: 220px 0 100px; } }

  .hero-container { max-width: 800px; }

  .hero-tag {
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--blue);
    margin-bottom: 28px;
  }

  .hero-h1 {
    font-size: clamp(38px, 6.5vw, 80px);
    line-height: 1.05;
    letter-spacing: -0.035em;
    margin: 0 0 32px;
  }

  .hero-sub {
    color: var(--text-secondary);
    font-size: 18px;
    line-height: 1.7;
    max-width: 580px;
    margin: 0 0 40px;
  }

  .hero-cta {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    margin-bottom: 48px;
  }
  @media (min-width: 640px) {
    .hero-cta { flex-direction: row; gap: 16px; }
  }

  .hero-trust-line {
    font-size: 13px;
    color: var(--text-muted);
    letter-spacing: 0.03em;
  }

  .hero-video {
    border-radius: 16px;
    overflow: hidden;
    padding: 0;
  }

  .vsl-intro { display: flex; flex-direction: column; align-items: center; gap: 8px; }
  .vsl-tag {
    font-size: 11px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--blue);
  }
  .vsl-title {
    font-size: 17px; color: var(--text-secondary); line-height: 1.5;
    max-width: 480px; text-align: center;
  }
</style>
