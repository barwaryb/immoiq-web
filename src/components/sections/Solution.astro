---
const services = [
  {
    num: '001',
    title: 'Portfolioanalyse',
    titleAccent: '— datenbasiert, nicht geraten',
    desc: 'Unsere KI analysiert jede Einheit deines Portfolios: Cashflow, Steuern, Finanzierung, Exit-Szenarien. Basierend auf Echtzeit-Marktdaten für jede Lage in Deutschland.',
  },
  {
    num: '002',
    title: 'Optimierungsstrategie',
    titleAccent: '— persönlich, nicht automatisiert',
    desc: 'Im 1:1 Strategiegespräch gehen wir deinen Report durch, priorisieren die Hebel und erstellen einen konkreten Umsetzungsplan — abgestimmt auf deine Situation.',
  },
  {
    num: '003',
    title: 'Umsetzung',
    titleAccent: '— mit System oder für dich',
    desc: 'DIY mit Videoakademie und Vorlagen. Oder unser Premium-Team übernimmt: Gutachten, Sanierungsfahrpläne, Mietanpassungen, Fördermittelanträge — komplett.',
  },
]
---

<section class="s-dark" id="results" style="padding: 140px 0 120px;">
  <div class="container">

    <div class="sol-header reveal">
      <p class="section-label" style="margin-bottom: 24px;">Was wir tun</p>
      <h2 class="sol-h2 gradient-title-dark">
        Drei Schritte zu einem<br/>Portfolio, das arbeitet.
      </h2>
    </div>

    <div class="sol-list">
      {services.map((s, i) => (
        <div class={`sol-item reveal ${i > 0 ? 'reveal-d' + i : ''}`}>
          <div class="sol-num">{s.num}</div>
          <div class="sol-content">
            <h3 class="sol-title">
              {s.title} <em>{s.titleAccent}</em>
            </h3>
            <p class="sol-desc">{s.desc}</p>
          </div>
        </div>
      ))}
    </div>

    <div style="margin-top: 64px; text-align:center;" class="reveal">
      <a href="#calendly" class="cta-btn">
        Erstgespräch vereinbaren
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12,5 19,12 12,19"/></svg>
      </a>
    </div>
  </div>
</section>

<style>
  .sol-header { margin-bottom: 64px; }
  .sol-h2 {
    font-size: clamp(32px, 5vw, 56px);
    line-height: 1.08;
    margin: 0;
  }

  .sol-list {
    max-width: 900px;
    border-top: 1px solid rgba(255,255,255,0.1);
  }

  .sol-item {
    display: flex;
    gap: 24px;
    padding: 48px 0;
    border-bottom: 1px solid rgba(255,255,255,0.1);
    align-items: flex-start;
  }
  @media (min-width: 768px) { .sol-item { gap: 48px; padding: 56px 0; } }

  .sol-num {
    font-family: 'JetBrains Mono', monospace;
    font-weight: 500; font-size: 14px;
    color: rgba(255,255,255,0.3);
    flex-shrink: 0; padding-top: 8px; min-width: 40px;
  }

  .sol-title {
    font-family: 'Satoshi', sans-serif;
    font-weight: 700; font-size: clamp(20px, 2.5vw, 28px);
    color: #fff; margin: 0 0 12px;
    letter-spacing: -0.02em; line-height: 1.3;
  }
  .sol-title em {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic; font-weight: 300;
    color: rgba(255,255,255,0.45);
  }

  .sol-desc {
    color: rgba(255,255,255,0.55);
    font-size: 15px; line-height: 1.7;
    margin: 0; max-width: 520px;
  }
</style>
