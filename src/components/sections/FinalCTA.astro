<section class="s-white" id="calendly" style="padding:120px 0 140px; text-align:center;">
  <div class="container" style="max-width:700px;">

    <p class="section-label reveal" style="margin-bottom:24px;">Jetzt starten</p>

    <h2 class="fc-h2 reveal">
      Jedes Jahr das vergeht,
      <br/><em class="italic-gradient">kostet dich Geld.</em>
    </h2>

    <p class="fc-sub reveal reveal-d1">
      Mieterhöhungen haben Fristen. Förderungen laufen aus. Steuervorteile verfallen.
      Je länger du wartest, desto mehr Potenzial ist weg.
    </p>

    <p class="fc-bold reveal reveal-d1">
      30 Minuten. Kostenlos. Danach weißt du, ob Potenzial da ist.
    </p>

    <div class="reveal reveal-d2" style="margin:40px 0;">
      <a href="#calendly" class="cta-btn">
        Kostenloses Strategiegespräch buchen
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12,5 19,12 12,19"/></svg>
      </a>
    </div>

    <p class="fc-trust reveal reveal-d3">
      12 Monate Geld-zurück-Garantie · Noch 7 Founders-Plätze
    </p>
  </div>
</section>

<style>
  .fc-h2 { font-size: clamp(32px, 5vw, 56px); line-height: 1.08; margin: 0 0 24px; }
  .fc-h2 em { /* styled via .italic-gradient */ }
  .fc-sub { color: var(--text-secondary); font-size: 18px; line-height: 1.7; margin: 0 0 16px; }
  .fc-bold { color: var(--text); font-weight: 600; font-size: 18px; margin: 0; }
  .fc-trust { color: var(--text-muted); font-size: 13px; }
</style>
