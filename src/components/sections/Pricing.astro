---
const diyFeatures = [
  'KI-Portfolioanalyse',
  '1:1 Strategiecall mit Max',
  'Optimierungsreport auf den Euro',
  'Videoakademie + Vorlagen',
  'E-Mail Support',
]

const premiumFeatures = [
  'Alles aus Analyse — plus:',
  'Professionelle Gutachten',
  'Sanierungsfahrpläne',
  'Mietanpassungs-Service',
  'Fördermittelanträge',
  'Persönlicher Ansprechpartner',
  '12 Monate Begleitung',
]
---

<section class="s-light" id="pricing" style="padding:140px 0 140px;">
  <div class="container">

    <div class="pr-header reveal" style="text-align:center; margin-bottom:64px;">
      <p class="section-label" style="margin-bottom:16px">Zwei Wege</p>
      <h2 class="pr-h2">
        Du entscheidest, wie viel<br/>
        <em class="italic-gradient">wir für dich übernehmen.</em>
      </h2>
      <p class="pr-sub">Beide Wege starten mit dem gleichen kostenlosen Erstgespräch.</p>
    </div>

    <div class="pr-grid reveal-stagger">

      <!-- DIY -->
      <div class="card pr-card">
        <div class="pr-card-header">
          <span class="pr-card-tag">Analyse</span>
          <h3 class="pr-card-title">Du setzt um</h3>
          <p class="pr-card-desc">Report + Fahrplan + Vorlagen. Du bekommst alles, was du brauchst — und setzt es selbst um.</p>
        </div>

        <div class="pr-card-price">
          <span class="pr-amount">4.900€</span>
          <span class="pr-terms">Einmalzahlung · Kein Abo</span>
        </div>

        <ul class="pr-features">
          {diyFeatures.map(f => (
            <li class="pr-feature">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--blue)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20,6 9,17 4,12"/></svg>
              {f}
            </li>
          ))}
        </ul>

        <div class="pr-card-cta">
          <a href="#calendly" class="cta-btn-outline" style="width:100%; justify-content:center;">
            Erstgespräch buchen
          </a>
        </div>
      </div>

      <!-- Premium -->
      <div class="card pr-card pr-card-premium">
        <span class="pr-popular">Beliebteste Wahl</span>
        <div class="pr-card-header">
          <span class="pr-card-tag pr-tag-premium">Premium</span>
          <h3 class="pr-card-title">Wir machen alles</h3>
          <p class="pr-card-desc">Analyse + Gutachten + Umsetzung. Wir optimieren dein gesamtes Portfolio — du lehnst dich zurück.</p>
        </div>

        <div class="pr-card-price">
          <span class="pr-amount">Auf Anfrage</span>
          <span class="pr-terms">Individuell nach Portfoliogröße</span>
        </div>

        <ul class="pr-features">
          {premiumFeatures.map(f => (
            <li class="pr-feature">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--blue)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20,6 9,17 4,12"/></svg>
              {f}
            </li>
          ))}
        </ul>

        <div class="pr-card-cta">
          <a href="#calendly" class="cta-btn" style="width:100%; justify-content:center;">
            Erstgespräch buchen
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12,5 19,12 12,19"/></svg>
          </a>
        </div>
      </div>

    </div>

    <!-- Guarantee -->
    <div class="pr-guarantee reveal" style="text-align:center; margin-top:48px;">
      <p class="pr-guarantee-text">
        🛡 12 Monate Geld-zurück-Garantie auf alle Pakete. Kein Risiko.
      </p>
    </div>

  </div>
</section>

<style>
  .pr-h2 { font-size: clamp(28px, 4.5vw, 48px); line-height: 1.1; margin: 0 0 16px; }
  .pr-sub { color: var(--text-muted); font-size: 16px; margin: 0; }

  .pr-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
    max-width: 860px;
    margin: 0 auto;
  }
  @media (min-width: 768px) {
    .pr-grid { grid-template-columns: 1fr 1fr; }
  }

  .pr-card {
    padding: 40px 32px;
    display: flex;
    flex-direction: column;
    position: relative;
  }

  .pr-card-premium {
    border-color: var(--blue);
    border-width: 2px;
  }

  .pr-popular {
    position: absolute;
    top: -13px; left: 50%; transform: translateX(-50%);
    background: var(--blue);
    color: #fff;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 5px 16px;
    border-radius: 99px;
    white-space: nowrap;
  }

  .pr-card-header { margin-bottom: 28px; }
  .pr-card-tag {
    font-size: 11px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--text-muted); display: block; margin-bottom: 8px;
  }
  .pr-tag-premium { color: var(--blue); }
  .pr-card-title {
    font-size: 26px; font-weight: 700; letter-spacing: -0.02em;
    margin: 0 0 8px;
  }
  .pr-card-desc {
    font-size: 14px; line-height: 1.6; color: var(--text-secondary); margin: 0;
  }

  .pr-card-price {
    padding: 20px 0;
    margin-bottom: 24px;
    border-top: 1px solid rgba(0,0,0,0.06);
    border-bottom: 1px solid rgba(0,0,0,0.06);
  }
  .pr-amount {
    display: block;
    font-family: 'JetBrains Mono', monospace;
    font-weight: 700;
    font-size: 36px;
    color: var(--text);
    letter-spacing: -0.02em;
  }
  .pr-terms {
    display: block; margin-top: 4px;
    font-size: 13px; color: var(--text-muted);
  }

  .pr-features {
    list-style: none; padding: 0; margin: 0 0 32px;
    display: flex; flex-direction: column; gap: 12px;
    flex: 1;
  }
  .pr-feature {
    display: flex; align-items: center; gap: 10px;
    font-size: 14px; color: var(--text-secondary);
  }

  .pr-card-cta { margin-top: auto; }

  .pr-guarantee-text { font-size: 14px; color: var(--text-muted); }
</style>
