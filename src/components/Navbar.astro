---
const navLinks = [
  { label: 'So funktioniert\'s', href: '#process' },
  { label: 'Ergebnisse',         href: '#results' },
  { label: 'Pricing',            href: '#pricing' },
  { label: 'FAQ',                href: '#faq' },
]
---

<header id="navbar" class="navbar">
  <div class="container navbar-inner">

    <a href="/" class="navbar-logo">
      <img src="/images/Logo/logo.png" alt="ImmoIQ" class="logo-img" />
      <span class="logo-text">Immo<span class="logo-accent">IQ</span></span>
    </a>

    <nav class="desktop-nav">
      {navLinks.map(link => (
        <a href={link.href} class="nav-link">{link.label}</a>
      ))}
    </nav>

    <a href="#calendly" class="cta-btn desktop-cta">
      Termin buchen
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12,5 19,12 12,19"/></svg>
    </a>

    <button id="hamburger" class="hamburger mobile-only" aria-label="Menü öffnen" aria-expanded="false">
      <span class="ham-line"></span>
      <span class="ham-line"></span>
      <span class="ham-line"></span>
    </button>

  </div>
</header>

<!-- Mobile sticky bottom CTA -->
<div id="mobile-bottom-cta" class="mobile-bottom-cta mobile-only">
  <a href="#calendly" class="cta-btn mobile-cta-btn">
    Kostenloses Strategiegespräch
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12,5 19,12 12,19"/></svg>
  </a>
</div>

<!-- Mobile menu -->
<div id="mobile-menu" class="mobile-menu mobile-only">
  <nav class="mobile-nav">
    {navLinks.map(link => (
      <a href={link.href} class="mobile-nav-link">{link.label}</a>
    ))}
  </nav>
  <a href="#calendly" class="cta-btn mobile-menu-cta">
    Kostenloses Strategiegespräch
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12,5 19,12 12,19"/></svg>
  </a>
</div>

<style>
  .navbar {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 50;
    transition: background 0.3s, border-color 0.3s;
    background: linear-gradient(180deg, rgba(255,255,255,0.95) 0%, rgba(255,255,255,0) 100%);
    border-bottom: 1px solid transparent;
  }
  .navbar.scrolled {
    background: rgba(255,255,255,0.96);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom-color: rgba(0,0,0,0.06);
  }

  .navbar-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
  }

  .navbar-logo {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-shrink: 0;
  }
  .logo-img {
    width: 36px; height: 36px;
    object-fit: contain;
  }
  .logo-text {
    font-family: 'Inter', sans-serif;
    font-weight: 700;
    font-size: 18px;
    color: var(--text);
    letter-spacing: -0.02em;
  }
  .logo-accent { color: #3388FF; }

  .desktop-nav {
    display: none;
    align-items: center;
    gap: 32px;
  }
  .nav-link {
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    font-weight: 500;
    color: rgba(0,0,0,0.5);
    transition: color 0.2s;
  }
  .nav-link:hover { color: var(--text); }

  .desktop-cta { display: none; }

  @media (min-width: 1024px) {
    .navbar-inner { height: 80px; }
    .desktop-nav { display: flex; }
    .desktop-cta { display: inline-flex; }
    .mobile-only { display: none !important; }
  }

  .hamburger {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 44px; height: 44px;
    padding: 10px;
  }
  .ham-line {
    display: block;
    width: 22px; height: 2px;
    background: var(--text);
    border-radius: 2px;
    transform-origin: center;
    transition: transform 0.3s ease, opacity 0.3s ease;
  }
  .hamburger.open .ham-line:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .hamburger.open .ham-line:nth-child(2) { opacity: 0; transform: scaleX(0); }
  .hamburger.open .ham-line:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  .mobile-menu {
    position: fixed;
    inset: 0;
    z-index: 45;
    background: var(--dark);
    display: flex;
    flex-direction: column;
    padding: 88px 24px 32px;
    transform: translateX(100%);
    transition: transform 0.35s cubic-bezier(0.16,1,0.3,1);
  }
  .mobile-menu.open {
    transform: translateX(0);
  }

  .mobile-nav {
    display: flex;
    flex-direction: column;
    flex: 1;
  }
  .mobile-nav-link {
    font-family: 'Cormorant Garamond', serif;
    font-size: 28px;
    font-weight: 400;
    color: #fff;
    padding: 16px 0;
    border-bottom: 1px solid rgba(255,255,255,0.1);
    display: block;
    transition: color 0.2s;
  }
  .mobile-nav-link:hover { color: rgba(255,255,255,0.6); }

  .mobile-menu-cta {
    margin-top: 32px;
    justify-content: center;
  }

  .mobile-bottom-cta {
    position: fixed;
    bottom: 0; left: 0; right: 0;
    z-index: 48;
    padding: 12px 16px 24px;
    background: linear-gradient(to top, rgba(255,255,255,0.98) 70%, transparent);
    transform: translateY(100%);
    transition: transform 0.4s cubic-bezier(0.16,1,0.3,1);
  }
  .mobile-bottom-cta.visible {
    transform: translateY(0);
  }
  .mobile-cta-btn {
    width: 100%;
    justify-content: center;
  }
</style>

<script>
  const navbar     = document.getElementById('navbar')
  const hamburger  = document.getElementById('hamburger')
  const mobileMenu = document.getElementById('mobile-menu')
  const bottomCta  = document.getElementById('mobile-bottom-cta')

  if (navbar && hamburger && mobileMenu) {
    let menuOpen = false

    window.addEventListener('scroll', () => {
      navbar.classList.toggle('scrolled', window.scrollY > 40)
      if (bottomCta) bottomCta.classList.toggle('visible', window.scrollY > 200 && !menuOpen)
    }, { passive: true })

    function openMenu() {
      menuOpen = true
      mobileMenu.classList.add('open')
      hamburger.classList.add('open')
      hamburger.setAttribute('aria-expanded', 'true')
      document.body.style.overflow = 'hidden'
      if (bottomCta) bottomCta.classList.remove('visible')
    }

    function closeMenu() {
      menuOpen = false
      mobileMenu.classList.remove('open')
      hamburger.classList.remove('open')
      hamburger.setAttribute('aria-expanded', 'false')
      document.body.style.overflow = ''
      if (bottomCta && window.scrollY > 200) bottomCta.classList.add('visible')
    }

    hamburger.addEventListener('click', () => menuOpen ? closeMenu() : openMenu())
    mobileMenu.querySelectorAll('a').forEach(a => a.addEventListener('click', closeMenu))
    document.addEventListener('keydown', e => { if (e.key === 'Escape' && menuOpen) closeMenu() })
  }
</script>
