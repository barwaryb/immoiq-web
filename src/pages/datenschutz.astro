---
import Layout from '../layouts/Layout.astro'
---

<Layout title="Datenschutz – ImmoIQ">
  <section class="s-white" style="padding:140px 0 96px;">
    <div class="container" style="max-width:760px;">
      <h1 style="font-size:36px; color:#0A0F1C; margin:0 0 32px;">Datenschutzerklärung</h1>
      <div style="color:#4A5568; font-size:16px; line-height:1.8;">
        <p>Der Schutz deiner Daten ist uns wichtig.</p>
        <p style="margin-top:32px; color:#9CA3AF; font-size:14px;">
          Die vollständige Datenschutzerklärung wird in Kürze ergänzt.
        </p>
      </div>
    </div>
  </section>
</Layout>
