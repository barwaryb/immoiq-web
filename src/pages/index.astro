  <!-- 5. BREAKER — Visuelles Atmen -->
  <ImageBreaker src="/images/breaker-2.jpg" />

  <!-- 6. AUTHORITY — Wer sind die Bertleins + Testimonial -->
  <Authority />

  <!-- 7. PROCESS — Wie funktioniert's (Sticky Cards) -->
