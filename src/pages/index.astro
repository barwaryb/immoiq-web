---
import Layout from '../layouts/Layout.astro'
import Hero from '../components/sections/Hero.astro'
import StatsBar from '../components/sections/StatsBar.astro'
import Problem from '../components/sections/Problem.astro'
import Solution from '../components/sections/Solution.astro'
import ImageBreaker from '../components/sections/ImageBreaker.astro'
import Authority from '../components/sections/Authority.astro'
